{
  "name": "@rp-cli/cli",
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "main": "dist/cli.js",
  "types": "dist/cli.d.ts",
  "files": [
    "dist"
  ],
  "bin": {
    "rp": "dist/cli.js"
  },
  "scripts": {
    "prebuild": "npm run build -w @rp-cli/core",
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc -p tsconfig.json",
    "postbuild": "chmod +x dist/cli.js",
    "prepack": "npm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@rp-cli/core": "0.0.0",
    "commander": "^14.0.3",
    "zod": "^4.4.2"
  }
}
