{
  "name": "@rp-cli/cli",
  "version": "0.1.0",
  "description": "Command-line tool for running RP CLI roleplay modules.",
  "keywords": [
    "rp-cli",
    "roleplay",
    "ai-agent"
  ],
  "license": "Apache-2.0",
  "author": "Yongkun Li",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Nativu5/rp-cli.git"
  },
  "bugs": {
    "url": "https://github.com/Nativu5/rp-cli/issues"
  },
  "homepage": "https://github.com/Nativu5/rp-cli#readme",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "main": "dist/cli.js",
  "types": "dist/cli.d.ts",
  "files": [
    "dist"
  ],
  "bin": {
    "rp": "dist/cli.js"
  },
  "scripts": {
    "prebuild": "npm run build -w @rp-cli/core",
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc -p tsconfig.json",
    "postbuild": "chmod +x dist/cli.js",
    "prepack": "npm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@rp-cli/core": "^0.1.0",
    "commander": "^14.0.3",
    "zod": "^4.4.2"
  }
}
